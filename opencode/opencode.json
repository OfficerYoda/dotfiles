{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "*": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "provider": {
    "anthropic": {
      "options": {
        "apiKey": "{env:HAI_PROXY_API_KEY}",
        "baseURL": "http://localhost:6655/anthropic/v1"
      }
    },
    "ollama": {
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6:35b-a3b-coding-nvfp4": {
          "name": "Qwen 3.6 35B-A3B Coding"
        }
      }
    }
  },
  "share": "disabled",
  "model": "anthropic/claude-opus-4-6",
  "small_model": "anthropic/claude-sonnet-4-6"
}
